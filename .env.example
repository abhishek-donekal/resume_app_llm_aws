# AWS Configuration
AWS_REGION=us-east-1
AWS_PROFILE=default
AWS_ROLE_ARN=arn:aws:iam::YOUR_ACCOUNT_ID:role/sagemaker-execution-role

# SageMaker Configuration
SAGEMAKER_ROLE_ARN=arn:aws:iam::YOUR_ACCOUNT_ID:role/sagemaker-execution-role
SAGEMAKER_INSTANCE_TYPE=ml.p3.2xlarge
SAGEMAKER_INSTANCE_COUNT=1
SAGEMAKER_BUCKET_NAME=your-sagemaker-bucket

# EC2 Configuration
EC2_INSTANCE_TYPE=g4dn.xlarge
EC2_KEY_NAME=your-key-pair
EC2_SECURITY_GROUP=your-security-group
EC2_AMI_ID=ami-0c55b159cbfafe1f0

# Model Configuration
MODEL_NAME=meta-llama/Llama-2-7b-hf
MODEL_ID=llama2-7b
OUTPUT_DIR=./model_output
CACHE_DIR=./model_cache

# Training Hyperparameters
BATCH_SIZE=4
EVAL_BATCH_SIZE=8
EPOCHS=3
LEARNING_RATE=2e-5
WARMUP_STEPS=100
WEIGHT_DECAY=0.01
MAX_SEQ_LENGTH=512

# LoRA Configuration (Parameter Efficient Fine-Tuning)
LORA_R=8
LORA_ALPHA=16
LORA_DROPOUT=0.05

# HuggingFace
HF_TOKEN=your_huggingface_token
HF_REPO_NAME=your-username/llama2-resume-customizer
HF_PRIVATE=false

# Ollama Configuration
OLLAMA_HOST=localhost:11434
OLLAMA_MODEL_NAME=resume-customizer

# FastAPI Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
LOG_LEVEL=info

# Monitoring & Logging
WANDB_API_KEY=your_wandb_api_key
WANDB_PROJECT=llama2-resume-customizer
LOG_FILE=./logs/training.log

# Inference Configuration
INFERENCE_MAX_LENGTH=512
INFERENCE_NUM_BEAMS=4
INFERENCE_TEMPERATURE=0.7
INFERENCE_TOP_P=0.9

# Data Configuration
DATA_INPUT_PATH=./data/raw/
DATA_OUTPUT_PATH=./data/processed/
TEST_SIZE=0.1
VALIDATION_SIZE=0.1

# Misc
DEBUG=false
SEED=42
